# Copiez ce fichier en .env et remplissez vos valeurs
# NE JAMAIS committer le fichier .env sur GitHub

# ── Supabase (Base de données) ────────────────────────────
# Obtenez ces valeurs sur https://supabase.com → Settings → API
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_KEY=votre_anon_public_key_ici

# ── Wave (Paiement) ────────────────────────────────────────
# Format: https://pay.wave.com/m/VOTRE_MERCHANT_ID/c/sn
WAVE_PAYMENT_URL=https://pay.wave.com/m/VOTRE_MERCHANT_ID/c/sn

# ── URL de votre site déployé ──────────────────────────────
# Ex: https://caravane-amicale.vercel.app
BASE_URL=https://VOTRE_DOMAINE.vercel.app
